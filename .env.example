# Local development
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=coldtrace_platform
MYSQL_PORT=3306
API_PORT=5271

# Authentication
# Generate a private value of at least 32 bytes. Do not commit the populated .env file.
JWT_SECRET=
JWT_EXPIRATION_DAYS=7

# Comma-separated exact browser origins. Docker Compose defaults to the two local Vite origins when blank.
# Production example: https://coldtrace-frontend-web.vercel.app,https://preview.example.com
CORS_ALLOWED_ORIGINS=

# Social authentication
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/identity-access/sign-in
GOOGLE_OAUTH_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_OIDC_JWKS_URI=https://www.googleapis.com/oauth2/v3/certs
GOOGLE_OIDC_ISSUER=https://accounts.google.com
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_REDIRECT_URI=http://localhost:5173/identity-access/sign-in
APPLE_OAUTH_TOKEN_URI=https://appleid.apple.com/auth/token
APPLE_OIDC_JWKS_URI=https://appleid.apple.com/auth/keys
APPLE_OIDC_ISSUER=https://appleid.apple.com
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Store the PKCS#8 private key with escaped newlines in environment configuration.
APPLE_PRIVATE_KEY=

# Cloud Run deployment
GCP_PROJECT_ID=coldtrace-platform-20260619
GCP_REGION=us-central1
SERVICE_NAME=coldtrace-platform
DB_INSTANCE_NAME=coldtrace-mysql
DATABASE_NAME=coldtrace_platform
DATABASE_USER=coldtrace_app
DB_SECRET_NAME=coldtrace-db-password
JWT_SECRET_NAME=coldtrace-jwt-secret
CLOUD_RUN_SERVICE_ACCOUNT_NAME=coldtrace-cloud-run-runtime
CLOUD_SQL_BACKUP_START_TIME=03:00
CORS_ALLOWED_ORIGINS=https://coldtrace-frontend-web.vercel.app,https://coldtrace-frontend-q1gkddcns-mauricio-pajes-projects.vercel.app,http://localhost:5173
FRONTEND_ORIGIN=https://coldtrace-frontend-web.vercel.app

# Google and Apple authentication
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_REDIRECT_URI=https://coldtrace-frontend-web.vercel.app/identity-access/sign-in
GOOGLE_OAUTH_CLIENT_SECRET_NAME=coldtrace-google-oauth-client-secret
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_REDIRECT_URI=https://coldtrace-frontend-web.vercel.app/identity-access/sign-in
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_SECRET_NAME=coldtrace-apple-private-key

# AI Assistance configuration
# Supported providers: ollama, openai
AI_ASSISTANCE_ENABLED=false
AI_MODEL_PROVIDER=disabled
AI_MODEL_NAME=
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_API_KEY=
OPENAI_API_KEY_SECRET_NAME=coldtrace-openai-api-key
AI_REQUEST_TIMEOUT=30s

# Stripe billing
STRIPE_OPERATIONS_PRICE_ID=
STRIPE_COMPLIANCE_AI_PRICE_ID=
STRIPE_SECRET_KEY_SECRET_NAME=coldtrace-stripe-secret-key
STRIPE_WEBHOOK_SECRET_NAME=coldtrace-stripe-webhook-secret
BILLING_CHECKOUT_SUCCESS_URL=https://coldtrace-frontend-web.vercel.app/settings/billing?checkout=success&session_id={CHECKOUT_SESSION_ID}
BILLING_CHECKOUT_CANCEL_URL=https://coldtrace-frontend-web.vercel.app/settings/billing?checkout=cancel
BILLING_CUSTOMER_PORTAL_RETURN_URL=https://coldtrace-frontend-web.vercel.app/settings/billing?portal=return
