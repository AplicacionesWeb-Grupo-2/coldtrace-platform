{
  "TokenSettings": {
    "Secret": "%JWT_SECRET%",
    "ExpirationDays": 7
  },
  "Authentication": {
    "Social": {
      "Google": {
        "ClientId": "%GOOGLE_OAUTH_CLIENT_ID%",
        "ClientSecret": "%GOOGLE_OAUTH_CLIENT_SECRET%",
        "RedirectUri": "%GOOGLE_OAUTH_REDIRECT_URI%",
        "TokenUri": "%GOOGLE_OAUTH_TOKEN_URI%",
        "JwksUri": "%GOOGLE_OIDC_JWKS_URI%",
        "Issuer": "%GOOGLE_OIDC_ISSUER%"
      },
      "Apple": {
        "ClientId": "%APPLE_OAUTH_CLIENT_ID%",
        "RedirectUri": "%APPLE_OAUTH_REDIRECT_URI%",
        "TokenUri": "%APPLE_OAUTH_TOKEN_URI%",
        "JwksUri": "%APPLE_OIDC_JWKS_URI%",
        "Issuer": "%APPLE_OIDC_ISSUER%",
        "TeamId": "%APPLE_TEAM_ID%",
        "KeyId": "%APPLE_KEY_ID%",
        "PrivateKey": "%APPLE_PRIVATE_KEY%"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "server=%DATABASE_URL%;port=3306;user=%DATABASE_USER%;password=%DATABASE_PASSWORD%;database=%DATABASE_SCHEMA%;sslmode=Disabled;AllowPublicKeyRetrieval=True"
  },
  "AiAssistance": {
    "Enabled": false,
    "Provider": "%AI_MODEL_PROVIDER%",
    "Model": "%AI_MODEL_NAME%",
    "Endpoint": "%OLLAMA_BASE_URL%",
    "ApiKey": "%OPENAI_API_KEY%",
    "RequestTimeout": "%AI_REQUEST_TIMEOUT%",
    "TimeoutSeconds": 30
  },
  "Billing": {
    "PlanCatalog": {
      "OperationsStripePriceId": "%STRIPE_OPERATIONS_PRICE_ID%",
      "ComplianceAiStripePriceId": "%STRIPE_COMPLIANCE_AI_PRICE_ID%"
    },
    "Stripe": {
      "SecretKey": "%STRIPE_SECRET_KEY%",
      "WebhookSigningSecret": "%STRIPE_WEBHOOK_SECRET%",
      "CheckoutSuccessUrl": "%BILLING_CHECKOUT_SUCCESS_URL%",
      "CheckoutCancelUrl": "%BILLING_CHECKOUT_CANCEL_URL%",
      "CustomerPortalReturnUrl": "%BILLING_CUSTOMER_PORTAL_RETURN_URL%"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
